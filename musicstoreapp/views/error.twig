{% extends 'layout.twig' %}

{% block title %} Error Page - uoMusic {% endblock %}

{% block body %}
  <div class="container" style="margin-top: 60px; text-align: center;">
    <h1>Error {{ error.status }}</h1>
    <p>{{ message }}</p>
    <p>{{ error.stack }}</p>
    <a href="/" class="btn btn-default">Volver al inicio</a>
  </div>
{% endblock %}
{% extends 'layout.twig' %}